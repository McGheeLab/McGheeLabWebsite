rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users — public read (team page needs this), own profile or admin write
    match /users/{userId} {
      allow read:  if true;
      allow write: if request.auth.uid == userId || isAdmin();
    }

    // Stories — public reads for published, owner or admin for writes
    match /stories/{storyId} {
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && request.auth.uid == resource.data.authorUid)
                  || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
      allow delete: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
    }

    // Invitations — anyone can read (for registration), admin creates, registering user marks used
    match /invitations/{tokenId} {
      allow read:   if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (request.auth != null
                        && resource.data.used == false
                        && request.resource.data.used == true);
      allow delete: if isAdmin();
    }

    // Research topics — public read, admin write
    match /research/{topicId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Team profiles (migrated non-user entries) — public read, admin write, auth user can claim
    match /teamProfiles/{profileId} {
      allow read:  if true;
      allow write: if isAdmin();
      // Allow authenticated user to claim an unclaimed profile (set registered=true)
      allow update: if request.auth != null
                    && resource.data.registered == false
                    && request.resource.data.registered == true
                    && request.resource.data.registeredUid == request.auth.uid;
    }

    // Project packages — public reads for published, owner or admin for writes
    match /projectPackages/{projectId} {
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && request.auth.uid == resource.data.authorUid)
                  || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
      allow delete: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
    }

    // Opportunities — public read, admin write
    match /opportunities/{oppId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // News posts — public reads for published, owner or admin for writes
    match /newsPosts/{postId} {
      allow read: if resource.data.status == 'published'
                  || (request.auth != null && request.auth.uid == resource.data.authorUid)
                  || isAdmin();
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
      allow delete: if request.auth != null &&
                    (request.auth.uid == resource.data.authorUid || isAdmin());
    }

    // Comments — public read, authenticated create, own or admin delete
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.authorUid;
      allow delete: if request.auth != null
                    && (request.auth.uid == resource.data.authorUid || isAdmin());
    }

    // Reactions — public read, authenticated create (own uid only), own delete
    match /reactions/{reactionId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;
    }

    // CV data — own read/write, admin can read any
    match /cvData/{userId} {
      allow read:  if request.auth != null
                   && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null
                   && request.auth.uid == userId;
    }

    // Schedules — reusable schedule definitions (classes, events, reviews, etc.)
    // Public read so schedule pages render; owner or admin manages lifecycle
    match /schedules/{scheduleId} {
      allow read:  if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
                    && (request.auth.uid == resource.data.ownerUid || isAdmin());
    }

    // Participants — linked to a schedule via scheduleId field
    // Public read for confirmed assignments; admin manages roster;
    // participants update own doc via auth OR invite key (no login needed)
    match /participants/{participantId} {
      allow read:  if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (request.auth != null
                        && resource.data.speakerUid == request.auth.uid)
                    || (resource.data.key != null
                        && resource.data.key == request.resource.data.key
                        && resource.data.scheduleId == request.resource.data.scheduleId);
      allow delete: if isAdmin();
    }

    // Classes — course listings for the classes page (public read, admin write)
    match /classes/{classId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // Class files — metadata for uploaded class materials
    // Public read so students can download; authenticated users can upload;
    // admin can update or delete any file
    match /classFiles/{fileId} {
      allow read:   if true;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }
  }
}
