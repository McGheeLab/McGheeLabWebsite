rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // User profile photos & CV — anyone can view, owner or admin can upload
    match /users/{userId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }

    // Story media — anyone can view, authenticated users can upload images or videos
    match /stories/{storyId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'video/mp4'
                       || request.resource.contentType == 'video/webm');
    }

    // News post media — anyone can view, authenticated users can upload images or videos
    match /news/{postId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'video/mp4'
                       || request.resource.contentType == 'video/webm');
    }

    // Project cover images — anyone can view, authenticated users can upload
    match /projects/{projectId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // CV imports (BibTeX, PDFs) — owner only (admin reads CV data via Firestore)
    match /cv/{userId}/{allPaths=**} {
      allow read:  if request.auth != null
                   && request.auth.uid == userId;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 20 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf'
                       || request.resource.contentType == 'text/plain'
                       || request.resource.contentType == 'application/x-bibtex');
    }

    // Class files — anyone can download, authenticated users can upload (50 MB limit)
    match /classes/{classId}/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Chat file uploads — authenticated read/write, 50 MB limit, any file type
    match /chat/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Procurement invoice PDFs — authenticated read, authenticated upload (20 MB PDF)
    match /procurement/{docId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType == 'application/pdf';
    }

    // Compliance certificates — authenticated read, owner upload (PDF or image, 10 MB)
    match /compliance/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');
    }
  }
}
